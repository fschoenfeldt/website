{# SVG hardcoded (lucide external-link) because the {% icon %} shortcode does not work inside Nunjucks macros #}
{% macro externalIcon(iconClasses = "") %}
    <svg
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="-mt-[3px] {{ iconClasses }}"
    >
        <path d="M15 3h6v6" />
        <path d="M10 14 21 3" />
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
    </svg>
{% endmacro %}

{% macro link(href, text = "", external = false, mailto = false, title = "", customClasses = "", sublabel = "", sublabelClasses = "", showIcon = false, iconClasses = "") %}
    <a
    href="{{ href }}"
    {% if title %}title="{{ title }}"{% endif %}
    {% if external %}target="_blank" rel="noopener noreferrer"{% endif %}
    {% if customClasses %}class="{% if external %}external {% endif %}{{ customClasses }}"{% endif %}
    >
        {% if caller %}
            {{ caller() }}
        {% else %}
            {{ text }}
        {% endif %}
        {% if sublabel or showIcon %}
            <span class="inline-block {% if sublabelClasses %}{{ sublabelClasses }}{% endif %}" aria-hidden="true">
                {{ sublabel }}
                {% if showIcon %}
                    {{ externalIcon(iconClasses) }}
                {% endif %}
            </span>
        {% endif %}
    </a>
{% endmacro %}